// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// 1. Users & Customers
// -----------------------------------------------------------------------------

enum Role {
  CUSTOMER
  ADMIN
}

model User {
  id               String   @id @default(uuid())
  email            String   @unique
  passwordHash     String?
  firstName        String?
  lastName         String?
  mobile           String?  @unique
  dob              DateTime?
  gender           String?
  occupation       String?
  bloodGroup       String?
  emergencyContact String?
  role             Role     @default(CUSTOMER)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  addresses     Address[]
  orders        Order[]
  appointments  Appointment[]
  subscriptions Subscription[]
  reviews            Review[]
  payments           PaymentTransaction[]
  memberships        Membership[]
  membershipPayments MembershipPayment[]
}

enum AddressType {
  SHIPPING
  BILLING
}

model Address {
  id         String      @id @default(uuid())
  userId     String
  street     String
  city       String
  state      String
  postalCode String
  country    String
  isDefault  Boolean     @default(false)
  type       AddressType @default(SHIPPING)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// -----------------------------------------------------------------------------
// 2. Products & E-Commerce
// -----------------------------------------------------------------------------

model Category {
  id          String  @id @default(uuid())
  name        String
  slug        String  @unique
  description String?

  products Product[]
}

enum DomainContext {
  HEALTH
  ESSENTIALS
  BOTH
}

model Product {
  id            String        @id @default(uuid())
  name          String
  slug          String        @unique
  description   String?
  price         Float
  stockQuantity Int           @default(0)
  categoryId    String
  imageUrl      String?
  domainContext DomainContext @default(BOTH)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  category   Category    @relation(fields: [categoryId], references: [id])
  orderItems OrderItem[]
  reviews    Review[]
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
}

model Order {
  id          String      @id @default(uuid())
  userId      String
  status      OrderStatus @default(PENDING)
  totalAmount Float
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user     User                 @relation(fields: [userId], references: [id])
  items    OrderItem[]
  payments PaymentTransaction[]
}

model OrderItem {
  id              String @id @default(uuid())
  orderId         String
  productId       String
  quantity        Int
  priceAtPurchase Float

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}

// -----------------------------------------------------------------------------
// 3. CRM & Admin Leads
// -----------------------------------------------------------------------------

enum LeadSource {
  CHATBOT
  POPUP
  CONTACT_FORM
}

enum LeadStatus {
  NEW
  CONTACTED
  CONVERTED
}

model Lead {
  id        String     @id @default(uuid())
  name      String?
  email     String?
  phone     String?
  source    LeadSource
  notes     String?    @db.Text
  status    LeadStatus @default(NEW)
  createdAt DateTime   @default(now())
}

// -----------------------------------------------------------------------------
// 4. Telemetry & Analytics
// -----------------------------------------------------------------------------

enum SiteDomain {
  HEALTH
  ESSENTIALS
}

model PageVisit {
  id        String     @id @default(uuid())
  sessionId String
  path      String
  domain    SiteDomain
  ipAddress String?
  location  String?
  timestamp DateTime   @default(now())
}

// -----------------------------------------------------------------------------
// 5. Full-Scale Enterprise Features (Bookings, Memberships, Reviews, Finance)
// -----------------------------------------------------------------------------

enum ServiceType {
  MINUTE_CLINIC
  HEALTH_CHAIR
  CONSULTATION
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

model Appointment {
  id          String            @id @default(uuid())
  userId      String
  serviceType ServiceType
  date        DateTime
  status      AppointmentStatus @default(SCHEDULED)
  notes       String?           @db.Text
  createdAt   DateTime          @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
}

model Subscription {
  id          String             @id @default(uuid())
  userId      String
  planName    String
  status      SubscriptionStatus @default(ACTIVE)
  startDate   DateTime           @default(now())
  renewalDate DateTime

  user     User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments PaymentTransaction[]
}

model Review {
  id        String   @id @default(uuid())
  userId    String
  productId String
  rating    Int
  comment   String?  @db.Text
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

model PaymentTransaction {
  id             String        @id @default(uuid())
  userId         String
  orderId        String?
  subscriptionId String?
  provider       String
  transactionId  String
  amount         Float
  status         PaymentStatus @default(PENDING)
  createdAt      DateTime      @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  order        Order?        @relation(fields: [orderId], references: [id])
  subscription Subscription? @relation(fields: [subscriptionId], references: [id])
}

// -----------------------------------------------------------------------------
// 6. Membership Management System
// -----------------------------------------------------------------------------

model MembershipPlan {
  id           String   @id @default(uuid())
  name         String
  description  String?
  price        Float
  duration     Int      // Duration in days (e.g. 365)
  features     String[] // Array of feature strings
  status       String   @default("ACTIVE") // ACTIVE, INACTIVE
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships Membership[]
}

enum MembershipStatus {
  ACTIVE
  EXPIRED
  SUSPENDED
  CANCELLED
}

model Membership {
  id             String           @id @default(uuid())
  membershipId   String           @unique // e.g. AIRO000000001
  userId         String
  planId         String
  status         MembershipStatus @default(ACTIVE)
  startDate      DateTime         @default(now())
  expiryDate     DateTime
  qrCode         String?          @db.Text
  barcode        String?          @db.Text
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  user         User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan         MembershipPlan          @relation(fields: [planId], references: [id])
  payments     MembershipPayment[]
  transactions MembershipTransaction[]
}

enum PaymentProviderStatus {
  CREATED
  AUTHORIZED
  CAPTURED
  REFUNDED
  FAILED
}

model MembershipPayment {
  id                 String                @id @default(uuid())
  membershipId       String?
  userId             String
  razorpayOrderId    String?
  razorpayPaymentId  String?
  amount             Float
  currency           String                @default("INR")
  status             PaymentProviderStatus @default(CREATED)
  paymentDate        DateTime?
  invoiceNumber      String?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  user       User        @relation(fields: [userId], references: [id])
  membership Membership? @relation(fields: [membershipId], references: [id])
}

enum TransactionType {
  NEW
  RENEWAL
  UPGRADE
  DOWNGRADE
  COMPLIMENTARY
}

model MembershipTransaction {
  id           String          @id @default(uuid())
  membershipId String
  type         TransactionType
  amount       Float
  remarks      String?         @db.Text
  createdAt    DateTime        @default(now())

  membership Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
}
